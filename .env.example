# ─────────────────────────────────────────────────────────────────────────────
# Real-Time News Streaming System — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# USAGE:
#   cp .env.example .env
#   Fill in BOT_TOKEN and CHANNEL_ID. All other values have safe defaults.
#   NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── TELEGRAM (REQUIRED) ─────────────────────────────────────────────────────
# Get BOT_TOKEN from @BotFather on Telegram
# CHANNEL_ID can be @yourchannel or -100xxxxxxxxxx (numeric ID)
BOT_TOKEN=
CHANNEL_ID=

# ─── KAFKA TOPICS ────────────────────────────────────────────────────────────
KAFKA_RAW_TOPIC=raw_news
KAFKA_PROCESSED_TOPIC=processed_news

# Telegram reads from this topic.
# Phase 1: raw_news | Phase 2 (recommended): processed_news
TELEGRAM_KAFKA_TOPIC=processed_news
KAFKA_GROUP_ID=telegram-consumer-group
# true (default): Telegram consumer group is suffixed by crawler mode
#   e.g. telegram-consumer-group-realtime / telegram-consumer-group-backfill
#   This keeps realtime and backfill offsets isolated, so switching modes is
#   predictable even when you reuse the same stack.
# false: use KAFKA_GROUP_ID as-is.
KAFKA_GROUP_ID_SCOPE_BY_MODE=true

# ─── CRAWLER MODE ─────────────────────────────────────────────────────────────
# realtime (default): only publishes articles with published_ts >= startup time.
#   Articles with no published_ts are skipped. No backlog replay on boot.
#   State file tracks seen URLs so the same article isn't re-sent across cycles.
#
# backfill: one-shot historical ingest of all current feed entries.
#   Ignores startup_ts and state file — re-publishes everything found.
#   Use with CLI flags for finer control:
#     --per-feed-limit 50       stop each feed after 50 articles
#     --days 7                  only articles from the last 7 days
#     --total-limit 500         hard cap across all feeds
#   Example:
#     docker compose run --rm crawler-service \
#       python main.py --mode backfill --days 7 --per-feed-limit 100
CRAWLER_MODE=realtime

# Re-fetch interval for realtime mode (seconds)
CRAWL_INTERVAL_SECONDS=60

# Max URL hashes in the persistent dedup state file (realtime mode)
CRAWLER_STATE_MAX_URLS=50000

# ─── PROCESSOR SERVICE ───────────────────────────────────────────────────────
PROCESSOR_GROUP_ID=processor-consumer-group
PROCESSOR_DEDUP_WINDOW=10000

# ─── TELEGRAM ALERT FILTER ───────────────────────────────────────────────────
# true (default): only send articles where should_alert=true (keyword rules match).
# false: send every article regardless of keyword rules.
# Phase 1 / raw_news payloads (no should_alert field) are always sent.
TELEGRAM_ONLY_ALERT_MATCHED=true

# ─── TELEGRAM OFFSET RESET ───────────────────────────────────────────────────
# latest (default): new consumer group starts from the latest offset.
#   Use with realtime mode — Telegram will not replay existing backlog.
# earliest: start from the beginning of the topic.
#   Use when you want Telegram to also deliver backfill articles.
# NOTE: this only affects NEW consumer groups with no committed offset.
#       If the group already has committed offsets, Kafka ignores this setting.
# With KAFKA_GROUP_ID_SCOPE_BY_MODE=true, each mode gets its own group by default.
KAFKA_AUTO_OFFSET_RESET=latest

# ─── LOGGING ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── MINIO (PHASE 3 — docker compose --profile storage up) ───────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=news-archive

# ─── ICEBERG WRITER (PHASE 3 — scaffold) ─────────────────────────────────────
ICEBERG_GROUP_ID=iceberg-writer-group
ICEBERG_BATCH_SIZE=100
ICEBERG_BATCH_TIMEOUT=60
