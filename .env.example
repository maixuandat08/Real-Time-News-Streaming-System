# ─────────────────────────────────────────────────────────────────────────────
# Real-Time News Streaming System — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# USAGE:
#   cp .env.example .env
#   Edit .env with your real values
#   NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ─── TELEGRAM (REQUIRED) ─────────────────────────────────────────────────────
# Get BOT_TOKEN from @BotFather on Telegram
# CHANNEL_ID can be @yourchannel or -100xxxxxxxxxx (numeric ID)
BOT_TOKEN=
CHANNEL_ID=

# ─── KAFKA ───────────────────────────────────────────────────────────────────
# Topic crawler publishes to
KAFKA_RAW_TOPIC=raw_news

# Phase 1: telegram reads raw_news
# Phase 2: change to processed_news (after Flink is running)
TELEGRAM_KAFKA_TOPIC=raw_news

# Consumer group for telegram-service
KAFKA_GROUP_ID=telegram-consumer-group

# ─── CRAWLER ─────────────────────────────────────────────────────────────────
# How often to crawl RSS feeds (seconds)
CRAWL_INTERVAL_SECONDS=60

# ─── LOGGING ─────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── MINIO (PHASE 3 — optional) ──────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=news-archive
