# ─────────────────────────────────────────────────────────────────────────────
# Real-Time News Streaming System — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# USAGE:
#   cp .env.example .env
#   Fill in your BOT_TOKEN and CHANNEL_ID. All other values have safe defaults.
#   NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── TELEGRAM (REQUIRED) ─────────────────────────────────────────────────────
# Get BOT_TOKEN from @BotFather on Telegram
# CHANNEL_ID can be @yourchannel or -100xxxxxxxxxx (numeric ID)
BOT_TOKEN=
CHANNEL_ID=

# ─── KAFKA ───────────────────────────────────────────────────────────────────
KAFKA_RAW_TOPIC=raw_news
KAFKA_PROCESSED_TOPIC=processed_news

# Telegram reads from this topic.
# Phase 1: raw_news | Phase 2 (recommended): processed_news
TELEGRAM_KAFKA_TOPIC=processed_news
KAFKA_GROUP_ID=telegram-consumer-group

# ─── CRAWLER ─────────────────────────────────────────────────────────────────
# live (default): runs indefinitely, tracks seen URLs in a state file.
# backfill: one-shot re-ingest of all current feed entries (ignores state).
#   Run backfill: docker compose run --rm crawler-service python main.py --mode backfill
#   With limit:   docker compose run --rm crawler-service python main.py --mode backfill --limit 100
#   With days:    docker compose run --rm crawler-service python main.py --mode backfill --days 7
CRAWLER_MODE=live

# Re-fetch interval for live mode (seconds)
CRAWL_INTERVAL_SECONDS=60

# Max URLs kept in the persistent state file (live mode dedup window)
CRAWLER_STATE_MAX_URLS=50000

# ─── PROCESSOR SERVICE ───────────────────────────────────────────────────────
PROCESSOR_GROUP_ID=processor-consumer-group
PROCESSOR_DEDUP_WINDOW=10000

# ─── TELEGRAM ALERT FILTER ───────────────────────────────────────────────────
# true (default): only send articles where should_alert=true (keyword rules match).
# false: send every article regardless of keyword rules.
# Phase 1 / raw_news payloads (no should_alert field) are always sent.
TELEGRAM_ONLY_ALERT_MATCHED=true

# ─── LOGGING ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── MINIO / ICEBERG STORAGE PROFILE ─────────────────────────────────────────
# Start the storage stack with:
#   docker compose --profile storage up --build
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
MINIO_BUCKET=news-archive

# Iceberg metadata catalog + table target
ICEBERG_CATALOG_NAME=news
ICEBERG_REST_URI=http://iceberg-rest:8181
ICEBERG_WAREHOUSE=s3://news-archive/warehouse
ICEBERG_NAMESPACE=news
ICEBERG_TABLE=processed_news

# Iceberg writer batch controls
ICEBERG_GROUP_ID=iceberg-writer-group
ICEBERG_BATCH_SIZE=100
ICEBERG_BATCH_TIMEOUT=60
